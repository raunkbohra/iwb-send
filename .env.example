# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iwb_send

# Node Environment
NODE_ENV=development
LOG_LEVEL=info

# NextAuth.js (for dashboard auth)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# AWS
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
API_DOMAIN=api.iwbsend.com
WEBHOOK_DOMAIN=hooks.iwbsend.com

# Vercel Deployment
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID_MARKETING=your-project-id
VERCEL_PROJECT_ID_DASHBOARD=your-project-id
VERCEL_PROJECT_ID_API=your-project-id

# Provider Credentials (stored in AWS Secrets Manager in production)
# Development only - do NOT use in production
TELNYX_API_KEY=your-telnyx-key
SPARROW_API_KEY=your-sparrow-key
AAKASH_API_KEY=your-aakash-key
META_WHATSAPP_API_TOKEN=your-meta-token
AWS_SES_REGION=ap-south-1

# Feature Flags
ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_WHATSAPP=true
ENABLE_VOICE=true

# Rate Limiting (in-memory MVP, upgrade to Redis in production)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# Wallet / Billing
INITIAL_WALLET_BALANCE_UNITS=1000000000

# Observability
ENABLE_TRACING=false
ENABLE_PROFILING=false
