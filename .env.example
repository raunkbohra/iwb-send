# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iwb_send_dev

# Environment
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3002

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# SQS Queues
SQS_SMS_HIGH_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-sms-high
SQS_SMS_BULK_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-sms-bulk
SQS_EMAIL_HIGH_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-email-high
SQS_EMAIL_BULK_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-email-bulk
SQS_WA_HIGH_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-wa-high
SQS_WA_BULK_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-wa-bulk
SQS_VOICE_HIGH_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-voice-high
SQS_VOICE_BULK_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-voice-bulk
SQS_WEBHOOK_DISPATCH_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/iwb-send-webhook-dispatch

# Provider Credentials (Secrets Manager references)
SPARROW_API_KEY=your-sparrow-api-key
AAKASH_API_KEY=your-aakash-api-key
TELNYX_API_KEY=your-telnyx-api-key
META_WA_ACCESS_TOKEN=your-meta-wa-token
META_WA_PHONE_ID=your-meta-wa-phone-id

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=iwb-send-files

# Feature Flags
ENABLE_EMAIL_CHANNEL=true
ENABLE_WA_CHANNEL=true
ENABLE_VOICE_CHANNEL=true

# Logging
LOG_LEVEL=debug
